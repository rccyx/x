#!/bin/bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_utils"

require_env "NEXT_PUBLIC_API_URL"
require_env "X_API_TOKEN"

echo "→ Purging view window from $NEXT_PUBLIC_API_URL"
curl -fsSL -X DELETE \
  "$NEXT_PUBLIC_API_URL/v1/purge-view-window" \
  -H "x-api-token: $X_API_TOKEN" \
  --connect-timeout 5 --max-time 30 \
  --retry 3 --retry-delay 2 --retry-connrefused

echo "✅ View window purge completed."

