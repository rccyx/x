{
  "name": "@ashgw/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "format": "prettier . --write",
    "format-check": "prettier --check .",
    "lint": "pnpm run lint:ts ",
    "lint-all": "pnpm run lint:ts && pnpm run lint:md && pnpm run format && pnpm run lint:knip && pnpm run lint:spelling",
    "lint:knip": "knip --production --strict --exclude exports,nsExports,types,nsTypes",
    "lint:md": "markdownlint \"**/*.md\" --config=.markdownlint.json --ignore-path=.markdownlintignore",
    "lint:spelling": "cspell \"**\" \".github/**/*\"",
    "lint:ts": "tsc --noEmit; eslint ."
  },
  "author": "",
  "dependencies": {
    "@ashgw/analytics": "workspace:*",
    "@ashgw/auth": "workspace:*",
    "@ashgw/constants": "workspace:*",
    "@ashgw/cross-runtime": "workspace:*",
    "@ashgw/db": "workspace:*",
    "@ashgw/email": "workspace:*",
    "@ashgw/env": "workspace:*",
    "@ashgw/error": "workspace:*",
    "@ashgw/logger": "workspace:*",
    "@ashgw/monitor": "workspace:*",
    "@ashgw/scheduler": "workspace:*",
    "@ashgw/security": "workspace:*",
    "@ashgw/storage": "workspace:*",
    "@ts-rest/core": "catalog:ts-rest3",
    "@ts-rest/open-api": "catalog:ts-rest3",
    "@ts-rest/react-query": "catalog:ts-rest3",
    "@ts-rest/serverless": "catalog:ts-rest3",
    "limico": "catalog:",
    "react": "catalog:react18",
    "react-dom": "catalog:react18",
    "react-hook-form": "catalog:rhf",
    "sharp": "catalog:",
    "superjson": "catalog:",
    "ts-rest-kit": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ashgw/eslint-config": "workspace:*",
    "@ashgw/next-config": "workspace:*",
    "@ashgw/playwright-config": "workspace:*",
    "@ashgw/prettier-config": "workspace:*",
    "@ashgw/tsconfig": "workspace:*",
    "@ashgw/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:react18",
    "@types/react-dom": "catalog:react18",
    "@vitest/ui": "catalog:",
    "prettier": "catalog:",
    "ts-roids": "catalog:",
