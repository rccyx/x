{
  "name": "@rccyx/storage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "format": "prettier . --write",
    "lint": "tsc --noEmit; eslint ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.803.0",
    "@aws-sdk/s3-request-presigner": "3.919.0",
    "@rccyx/env": "workspace:*",
    "@rccyx/logger": "workspace:*",
    "@rccyx/runner": "workspace:*"
  },
  "devDependencies": {
    "@rccyx/eslint-config": "workspace:*",
    "@rccyx/tsconfig": "workspace:*",
    "ts-roids": "catalog:",
    "typescript": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "src/index.ts"
      ]
    }
  }
}
