{
  "name": "@rccyx/seeder",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "format": "prettier . --write",
    "lint": "tsc --noEmit && eslint .",
    "seed": "pnpm --filter @rccyx/db migrate:reset --force && tsx src/index.ts"
  },
  "dependencies": {
    "@rccyx/db": "workspace:*",
    "@rccyx/env": "workspace:*",
    "@rccyx/logger": "workspace:*",
    "@rccyx/security": "workspace:*",
    "aws-sdk": "2.1692.0"
  },
  "devDependencies": {
    "@rccyx/eslint-config": "workspace:*",
    "@rccyx/tsconfig": "workspace:*",
    "ts-roids": "catalog:",
    "tsx": "^4.19.4",
    "typescript": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "src/index.ts"
      ]
    }
  }
}
