{
  "name": "@ashgw/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "build:vercel-preview": "vercel build --yes",
    "build:vercel-production": "vercel build --prod --yes",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "deploy:vercel-preview": "vercel deploy --prebuilt",
    "deploy:vercel-production": "vercel deploy --prod --prebuilt",
    "dev": "next dev -p 3000",
    "format": "prettier . --write",
    "format-check": "prettier --check .",
    "lint": "pnpm run lint:ts ",
    "lint-all": "pnpm run lint:ts && pnpm run lint:md && pnpm run format && pnpm run lint:knip && pnpm run lint:spelling",
    "lint:knip": "knip --production --strict --exclude exports,nsExports,types,nsTypes",
    "lint:md": "markdownlint \"**/*.md\" --config=.markdownlint.json --ignore-path=.markdownlintignore",
    "lint:spelling": "cspell \"**\" \".github/**/*\"",
    "lint:ts": "tsc --noEmit; eslint .",
    "postbuild": "echo 'next-sitemap'",
    "start": "next start",
    "test": "pnpm test:unit-integration; pnpm test:e2e",
    "test:e2e": "cd test/e2e && npx playwright test",
    "test:unit-integration": "vitest run --config=vitest.config.ts",
    "with-env": "dotenv -e ../../.env --"
  },
  "author": "",
  "dependencies": {
    "@ashgw/analytics": "workspace:*",
    "@ashgw/api": "workspace:*",
    "@ashgw/constants": "workspace:*",
    "@ashgw/cross-runtime": "workspace:*",
    "@ashgw/design": "workspace:*",
    "@ashgw/env": "workspace:*",
    "@ashgw/logger": "workspace:*",
    "@ashgw/monitor": "workspace:*",
    "next": "catalog:",
    "react": "catalog:react18",
    "react-dom": "catalog:react18",
    "react-hook-form": "catalog:rhf",
    "sharp": "catalog:",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ashgw/design": "workspace:*",
    "@ashgw/eslint-config": "workspace:*",
    "@ashgw/next-config": "workspace:*",
    "@ashgw/playwright-config": "workspace:*",
    "@ashgw/prettier-config": "workspace:*",
    "@ashgw/tsconfig": "workspace:*",
    "@ashgw/vitest-config": "workspace:*",
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:react18",
    "@types/react-dom": "catalog:react18",
    "@vitest/ui": "catalog:",
    "autoprefixer": "catalog:",
    "jiti": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "ts-roids": "catalog:",
    "typescript": "catalog:",
    "vercel": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "20.x"
  },
  "exports": {
    "./v1": "./src/transports/v1/index.ts",
    "./rpc": "./src/transports/rpc/index.ts",
    "./ts-rest": "./src/ts-rest/index.ts",
    "./trpc": "./src/trpc/index.ts",
    "./uri": "./src/uri.ts"
  },
  "keywords": [],
  "license": "ISC",
  "type": "module"
}
